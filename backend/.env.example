# ─────────────────────────────────────────────
#  .env.example – Template for required secrets
#
#  Copy this file to `.env` and fill in real values.
#  The `.env` file must NEVER be committed to git.
# ─────────────────────────────────────────────

# ── Claude API ────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Claude model to use (default: claude-opus-4-5)
# CLAUDE_MODEL=claude-opus-4-5

# ── Wake Word ─────────────────────────────────
# Name of the openwakeword model (default: hey_jarvis)
# WAKE_WORD_MODEL=hey_jarvis
# WAKE_WORD_THRESHOLD=0.5

# ── Microphone ────────────────────────────────
# Leave blank to use the system default microphone
# MIC_DEVICE_INDEX=
# MIC_SAMPLE_RATE=16000
# MIC_CHANNELS=1

# ── faster-whisper STT ────────────────────────
# Model size: tiny | base | small | medium | large-v2 | large-v3 | large-v3-turbo
# WHISPER_MODEL_SIZE=large-v3-turbo
# Device: cuda (GPU) or cpu
# WHISPER_DEVICE=cuda
# WHISPER_COMPUTE_TYPE=float16
# Smaller model used automatically if CUDA fails and STT falls back to CPU
# WHISPER_CPU_FALLBACK_MODEL=base
# WHISPER_LANGUAGE=en

# ── Text-to-Speech (Kokoro-82M) ───────────────
# Voice ID (e.g., am_michael, am_fenrir, am_puck)
# TTS_VOICE=am_michael
# TTS_SPEED=1.1

# ── FastAPI Server ────────────────────────────
# Shared secret for the control/events API — the frontend must send it on
# /start, /stop (Authorization: Bearer <token>) and /events (?token=<token>).
# Required: with it unset, those endpoints reject every request.
# Generate one:  python -c "import secrets; print(secrets.token_urlsafe(32))"
JARVIS_API_TOKEN=
# SERVER_HOST=127.0.0.1
# SERVER_PORT=8000
# SERVER_RELOAD=false

# ── Logging ───────────────────────────────────
# LOG_LEVEL=INFO
# LOG_FILE=logs/jarvis.log

# ── Email ─────────────────────────────────────
# Google Cloud OAuth "Web application" client with the Gmail API enabled.
# Register redirect URI: <GOOGLE_OAUTH_REDIRECT_BASE>/email/accounts/gmail/oauth-callback
# (default: http://localhost:8000/email/accounts/gmail/oauth-callback)
# Required for connecting Gmail accounts; IMAP-only accounts work without these.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_BASE=http://localhost:8000
# How often (seconds) to poll connected email accounts for new mail.
# EMAIL_POLL_INTERVAL_S=240
